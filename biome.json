{
    "$schema": "https://biomejs.dev/schemas/2.4.13/schema.json",
    "files": {
        "includes": [
            "**/*.ts",
            "**/*.tsx",
            "**/*.js",
            "**/*.jsx",
            "**/*.json",
            "!node_modules",
            "!server",
            "!server/**/*",
            "!pb-migrations",
            "!pb-migrations/**/*"
        ]
    },
    "formatter": {
        "enabled": true,
        "indentStyle": "space",
        "indentWidth": 4,
        "lineWidth": 120
    },
    "javascript": {
        "formatter": {
            "quoteStyle": "single",
            "trailingCommas": "es5",
            "semicolons": "asNeeded"
        }
    },
    "linter": {
        "enabled": true,
        "rules": {
            "recommended": true,
            "style": {
                "useConst": "error",
                "useTemplate": "error"
            },
            "suspicious": {
                "noExplicitAny": "error"
            },
            "correctness": {
                "noUnusedVariables": "warn"
            }
        }
    },
    "overrides": [
        {
            "includes": ["tests/**", "scripts/**", "**/*.test.ts", "**/*.test.tsx", "**/*.spec.ts"],
            "linter": {
                "rules": {
                    "suspicious": { "noConsole": "off" },
                    "style": { "noNonNullAssertion": "off" }
                }
            }
        }
    ]
}
